  <section id="part4">
    <div class="contact">
        <h1 class="text">Contact and Support</h1>
        <p class="intro">
            <b>Contact With Us</b>
            <br>
            We are here to provide you with the best service for your car rental needs.  
            <br>If you have any questions, special requests, or wish to book a car, please contact us through the following methods, and we will be happy to assist you!</p>
        <form class="contact-form">
            <div class="input-group">
                <label for="address"><b>Address:</b></label>
                <input type="text" id="address" placeholder="Your Address">
            </div>
            <div class="input-group">
                <label for="phone"><b>Phone:</b></label>
                <input type="text" id="phone" placeholder="Your Phone Number">
            </div>
            <div class="input-group">
                <label for="email"><b>Email:</b></label>
                <input type="email" id="email" placeholder="Your Email">
            </div>
            <div class="working-hours">
                <b>Working Hours:</b>
                <br>
                Monday  – Friday: 08:00 - 18:00<br>
                Saturday – Friday: 10:00 - 14:00
            </div>
            <h3>Questions and Reservations:</h3>
            <div class="input-group">
                <input type="text" placeholder="Type your question here">
            </div>
            <div class="input-group">
                <label for="date">Date:</label>
                <input type="date" id="date">
            </div>
            <div class="input-group">
                <label for="time">Time:</label>
                <input type="time" id="time">
            </div>
            <div class="input-group">
                <label for="pickup-location">Car pickup-location:</label>
                <input type="text" id="pickup-location" placeholder="Car Location">
            </div>
            <div class="input-group">
                <label for="dropoff-location">Car dropoff-location:</label>
                <input type="text" id="dropoff-location" placeholder="Car Location">
            </div>
            <button type="submit" class="submit-btn">Submit</button>
        </form>
    </div>
    
